# =========================================================================
# Spring Boot (Backend) Gitignore
# =========================================================================
backend/target/
backend/*.class
backend/*.log
backend/*.jar
backend/*.war
backend/*.ear
backend/.idea/
backend/.classpath
backend/.project
backend/.settings/
backend/*.iml
backend/*.ipr
backend/*.iws
backend/bin/
backend/.factorypath

# =========================================================================
# React Vite (Frontend) Gitignore
# =========================================================================
frontend/node_modules/
frontend/dist/
frontend/dist-ssr/
frontend/*.local
frontend/.env.local
frontend/.env.development.local
frontend/.env.test.local
frontend/.env.production.local

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# =========================================================================
# Common / Editor Gitignore
# =========================================================================
.vscode/*
!.vscode/extensions.json
.idea/
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
Thumbs.db
